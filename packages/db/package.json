{
  "name": "@bav/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/prisma.ts",
    "./mongo": "./src/mongo.ts",
    "./mongo/*": "./src/mongo/*.ts",
    "./enums": "./src/enums.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "seed": "tsx ./src/seed.ts",
    "ingest:ebay": "tsx ./src/ingest-ebay.ts",
    "ingest:public": "tsx ./src/ingest-ebay-public.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.13",
    "mongoose": "^8.9.3",
    "prisma": "^5.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
