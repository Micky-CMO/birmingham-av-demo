# ============================================================================
# Birmingham AV — Next.js web app environment (example)
# ----------------------------------------------------------------------------
# Copy to .env.local and fill in real values for local development. Only
# variables prefixed with NEXT_PUBLIC_ are shipped to the browser; everything
# else is server-only.
# ============================================================================

# Canonical origin. Drives metadataBase, sitemap URLs, and all absolute links
# in JSON-LD (Product, Organization, Breadcrumb).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UK VAT number for schema.org/Organization. Placeholder format matches the
# real HMRC format (GB + 9 digits) so validators pass in development.
NEXT_PUBLIC_VAT_NUMBER=GB123456789
